        </mxCell>
        <mxCell id="r_O9DxhbkYIy_wtXQPaM-2" parent="1" style="text;whiteSpace=wrap;" value="&lt;mxGraphModel dx=&quot;1050&quot; dy=&quot;700&quot; grid=&quot;1&quot; gridSize=&quot;10&quot; guides=&quot;1&quot; tooltips=&quot;1&quot; connect=&quot;1&quot; arrows=&quot;1&quot; fold=&quot;1&quot; page=&quot;1&quot; pageScale=&quot;1&quot; pageWidth=&quot;827&quot; pageHeight=&quot;1169&quot; math=&quot;0&quot; shadow=&quot;0&quot;&gt;&#xa;  &lt;root&gt;&#xa;    &lt;mxCell id=&quot;0&quot; /&gt;&#xa;    &lt;mxCell id=&quot;1&quot; parent=&quot;0&quot; /&gt;&#xa;    &#xa;    &lt;mxCell id=&quot;n_box1&quot; value=&quot;【前置阶段】日前时空概率推演与全局风险辨识&quot; style=&quot;swimlane;whiteSpace=wrap;html=1;fillColor=#ebf2fc;strokeColor=#a0c4ff;fontStyle=1;startSize=23;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&#xa;      &lt;mxGeometry x=&quot;154&quot; y=&quot;90&quot; width=&quot;420&quot; height=&quot;210&quot; as=&quot;geometry&quot; /&gt;&#xa;    &lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;n_mc_in&quot; value=&quot;输入历史统计概率矩阵&amp;lt;br&amp;gt;(入离站时段、初始SOC概率、里程概率分布)&quot; style=&quot;shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fontSize=11;&quot; vertex=&quot;1&quot; parent=&quot;n_box1&quot;&gt;&#xa;      &lt;mxGeometry x=&quot;40&quot; y=&quot;35&quot; width=&quot;340&quot; height=&quot;40&quot; as=&quot;geometry&quot; /&gt;&#xa;    &lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;n_mc_sim&quot; value=&quot;大规模蒙特卡洛随机抽样与时空演化模拟&amp;lt;br&amp;gt;（演化生成全天 EV 集群无控充电功率基准空间）&quot; style=&quot;rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;&quot; vertex=&quot;1&quot; parent=&quot;n_box1&quot;&gt;&#xa;      &lt;mxGeometry x=&quot;50&quot; y=&quot;95&quot; width=&quot;320&quot; height=&quot;40&quot; as=&quot;geometry&quot; /&gt;&#xa;    &lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;n_risk_id&quot; value=&quot;辨识未来时段局部断面/变压器潜在越限风险&amp;#lt;br&amp;gt;确定电网热稳定约束下的「日前安全控制裕度红线」&quot; style=&quot;rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1&quot; vertex=&quot;1&quot; parent=&quot;n_box1&quot;&gt;&#xa;      &lt;mxGeometry x=&quot;50&quot; y=&quot;155&quot; width=&quot;320&quot; height=&quot;40&quot; as=&quot;geometry&quot; /&gt;&#xa;    &lt;/mxCell&gt;&#xa;    &#xa;    &lt;mxCell id=&quot;n_box2&quot; value=&quot;【运行阶段】计及日前红线指导的实时多维动态调控&quot; style=&quot;swimlane;whiteSpace=wrap;html=1;fillColor=#f2f9f2;strokeColor=#b7e1b7;fontStyle=1;startSize=23;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&#xa;      &lt;mxGeometry x=&quot;154&quot; y=&quot;330&quot; width=&quot;420&quot; height=&quot;380&quot; as=&quot;geometry&quot; /&gt;&#xa;    &lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;n_real_in&quot; value=&quot;实时抽取站端真实互联数据&amp;lt;br&amp;gt;(当前在线EV实时SOC、桩端在线功率、动态PV出力)&quot; style=&quot;shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fontSize=11;&quot; vertex=&quot;1&quot; parent=&quot;n_box2&quot;&gt;&#xa;      &lt;mxGeometry x=&quot;40&quot; y=&quot;35&quot; width=&quot;340&quot; height=&quot;40&quot; as=&quot;geometry&quot; /&gt;&#xa;    &lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;n_time_ctrl&quot; value=&quot;结合日前安全红线开展时域优化控制&amp;lt;br&amp;gt;平衡PV大发区间，避免单纯实时调控引发的后期需求堆积&quot; style=&quot;rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;&quot; vertex=&quot;1&quot; parent=&quot;n_box2&quot;&gt;&#xa;      &lt;mxGeometry x=&quot;50&quot; y=&quot;100&quot; width=&quot;320&quot; height=&quot;40&quot; as=&quot;geometry&quot; /&gt;&#xa;    &lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;n_judge1&quot; value=&quot;实时潮流核算：&amp;lt;br&amp;gt;关键节点反向负载率 λ &amp;lt;br&amp;gt;是否超越热稳定越限红线？&quot; style=&quot;rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;&quot; vertex=&quot;1&quot; parent=&quot;n_box2&quot;&gt;&#xa;      &lt;mxGeometry x=&quot;85&quot; y=&quot;165&quot; width=&quot;250&quot; height=&quot;75&quot; as=&quot;geometry&quot; /&gt;&#xa;    &lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;n_space_ctrl&quot; value=&quot;空域动态限额精准拦截（解决突发无序车流短时越限）&amp;lt;br&amp;gt;基于车辆充电紧迫度动态分配各节点充电功率上限&quot; style=&quot;rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;&quot; vertex=&quot;1&quot; parent=&quot;n_box2&quot;&gt;&#xa;      &lt;mxGeometry x=&quot;50&quot; y=&quot;265&quot; width=&quot;320&quot; height=&quot;45&quot; as=&quot;geometry&quot; /&gt;&#xa;    &lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;n_judge2&quot; value=&quot;所有节点运行指标收敛&amp;lt;br&amp;gt;且满足车主离站期望SOC？&quot; style=&quot;rhombus;whiteSpace=wrap;html=1;&quot; vertex=&quot;1&quot; parent=&quot;n_box2&quot;&gt;&#xa;      &lt;mxGeometry x=&quot;100&quot; y=&quot;325&quot; width=&quot;220&quot; height=&quot;45&quot; as=&quot;geometry&quot; /&gt;&#xa;    &lt;/mxCell&gt;&#xa;    &#xa;    &lt;mxCell id=&quot;n_out&quot; value=&quot;输出具备全局安全保障的&amp;lt;br&amp;gt;分布式电源最大接入承载力裕度求解结果&quot; style=&quot;shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&#xa;      &lt;mxGeometry x=&quot;214&quot; y=&quot;740&quot; width=&quot;300&quot; height=&quot;45&quot; as=&quot;geometry&quot; /&gt;&#xa;    &lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;n_start&quot; value=&quot;开始&quot; style=&quot;ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&#xa;      &lt;mxGeometry x=&quot;314&quot; y=&quot;30&quot; width=&quot;100&quot; height=&quot;35&quot; as=&quot;geometry&quot; /&gt;&#xa;    &lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;n_end&quot; value=&quot;结束&quot; style=&quot;ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;&quot; vertex=&quot;1&quot; parent=&quot;1&quot;&gt;&#xa;      &lt;mxGeometry x=&quot;314&quot; y=&quot;810&quot; width=&quot;100&quot; height=&quot;35&quot; as=&quot;geometry&quot; /&gt;&#xa;    &lt;/mxCell&gt;&#xa;    &#xa;    &lt;mxCell id=&quot;e1&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;n_start&quot; target=&quot;n_mc_in&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;e2&quot; edge=&quot;1&quot; parent=&quot;n_box1&quot; source=&quot;n_mc_in&quot; target=&quot;n_mc_sim&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;e3&quot; edge=&quot;1&quot; parent=&quot;n_box1&quot; source=&quot;n_mc_sim&quot; target=&quot;n_risk_id&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;e4&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;n_risk_id&quot; target=&quot;n_real_in&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;e5&quot; edge=&quot;1&quot; parent=&quot;n_box2&quot; source=&quot;n_real_in&quot; target=&quot;n_time_ctrl&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;e6&quot; edge=&quot;1&quot; parent=&quot;n_box2&quot; source=&quot;n_time_ctrl&quot; target=&quot;n_judge1&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;e7&quot; value=&quot;是（面临日前未预见突发性越限）&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;&quot; edge=&quot;1&quot; parent=&quot;n_box2&quot; source=&quot;n_judge1&quot; target=&quot;n_space_ctrl&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;e8&quot; value=&quot;否&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;&quot; edge=&quot;1&quot; parent=&quot;n_box2&quot; source=&quot;n_judge1&quot; target=&quot;n_judge2&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot;&gt;&lt;array points=&quot;20,203,20,348&quot; /&gt;&lt;/mxGeometry&gt;&lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;e9&quot; edge=&quot;1&quot; parent=&quot;n_box2&quot; source=&quot;n_space_ctrl&quot; target=&quot;n_judge2&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;e10&quot; value=&quot;是&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;n_judge2&quot; target=&quot;n_out&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;e11&quot; value=&quot;否（执行电网侧降容迭代）&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;n_judge2&quot; target=&quot;n_time_ctrl&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot;&gt;&lt;array points=&quot;530,678,530,450&quot; /&gt;&lt;/mxGeometry&gt;&lt;/mxCell&gt;&#xa;    &lt;mxCell id=&quot;e12&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;n_out&quot; target=&quot;n_end&quot;&gt;&lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&lt;/mxCell&gt;&#xa;  &lt;/root&gt;&#xa;&lt;/mxGraphModel&gt;" vertex="1">
